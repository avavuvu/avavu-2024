<style>
    a {
        all: unset;
        cursor: pointer;
    }

    text {
        fill: blue;
        font-size: 30px;
        font-weight: bolder;
        text-decoration:underline;
    }
    .header {
        position: sticky;
        top: 0;
        left: 0;
        
        height: 120px;
        display: flex;
        justify-content: center;

        margin-top: 30px;

        user-select: none;
        pointer-events: none;
    }

    svg { 
        height: 100%;
        
    }

    path {
        stroke: blue;
        stroke-width: 8;
        stroke-dasharray: 300;
        stroke-dashoffset: 300;
        animation: scroll 10s ease infinite;
    }

    @keyframes scroll {
        0% {
            stroke-dashoffset: 0;
        }
        50% {
            stroke-dashoffset: 1000;
        }
        100% {
            stroke-dashoffset: 0;
        }
    }

</style>
---
export const prerender = false

// we are using the old style of document, eventually we will upgrade to the standard style but in the mean time we do this :)
import type { OldDocumentBundle } from "../../components/games/crossword/types"

const crosswords: {id: string, doc: OldDocumentBundle}[] = []

const displayData = crosswords.reverse().map(crossword => {return  {
    date: new Date(crossword.doc.date).toDateString(),

    id: crossword.id,

    stars: "🌶️".repeat(crossword.doc.difficulty),

    name: (crossword.doc.name === "") ? undefined : crossword.doc.name,
    
    size: {
            x: Math.max(...crossword.doc.grid.map(column => column.array.length)),
            y: crossword.doc.grid.length
        },

    grid: crossword.doc.grid.map(row => 
            row.array.map(char => 
                (char === ".") ? 
                    "■" : 
                    "□"
            )
            .join("")).join("\n")
}})
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="generator" content={Astro.generator}>
    <link rel="icon" type="image/svg+xml" href="/svg/crossword_favicon.svg">
    <title>Past Puzzles</title>
    <style>
        * {
            font-family: Arial, Helvetica, sans-serif;
        }
    </style>
    <meta name="description" content="Get access to a free archive of mini crosswords!">
</head>
<body>


    <main>
        <div class="content">
            <div class="header">
                <div style="width:">
                    
                    
                </div>
                <h1 class="title">
                    Crosswords
                </h1>
                <p>Every puzzle that has previously featured.</p>
                <hr>
            </div>

            <div class="crosswords">
                {
                    displayData.map(crossword => (
                        <a href={`/games/crossword?id=${crossword.id}`} class="crossword">
                            <div class="puzzle-info">
                                <h2 class="data">{crossword.size.x}×{crossword.size.y} {(crossword.name !== "" && crossword.name) ? `- ${crossword.name}` : ""}</h2>
                                <p class="date">{crossword.date}</p>
                                <h3 class="difficulty">{crossword.stars}</h3>
                            </div>
                            <div class="puzzle-layout">
                                <pre class="layout">{crossword.grid}</pre>
                            </div>
                            
                            
                        </a>
                    ))
                }
            </div>
            
        </div>
    </main>

</body>
</html>

<style>
    * {
        font-family: "PTRootUI";
        margin: 0;
    }

    .layout {
        font-family: 'Courier New', Courier, monospace;
        line-height: 0.59;
        font-size: xx-large;
        transform: rotate(-90deg) scaleX(-1); /* THIS IS AN INSANE BODGE BUT IDGAF*/
    }

    .crosswords {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .crossword {
        all: unset;
        cursor: pointer;
        
        display: grid;
        grid-template-columns: 3fr 1fr;
        width: min(80%, 100ch);
        background-color: blue;
        color: white;
        padding: 1rem;
        margin: 1rem 0;
        border-radius: 1rem;
    }

    .crossword:hover {
        background-color: rgb(40, 29, 196);
    }

    .puzzle-info {
        padding: 0.5rem;
    }

    .puzzle-layout {
        padding: .5rem;
        margin: 0.1rem;
        border-radius: 1rem;
        background-color: white;
        color: black;
        text-align: center;

    }
    main {
        display: flex;
        justify-content: center;
    }

    .title {
        
    }

    .content {
        width: 50ch;
        margin: 6rem 0;
    }
</style>